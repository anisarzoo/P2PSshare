PORT=9000
HOST=0.0.0.0
PEER_PATH=/peerjs
TRUST_PROXY=false

# Use "*" for public allow, or comma-separated origins for production lock-down.
CORS_ORIGIN=*
RATE_LIMIT=240
RATE_LIMIT_WINDOW_MS=60000
ALLOW_DISCOVERY=false

# Optional direct TLS. In production, TLS termination via reverse proxy is preferred.
ENABLE_HTTPS=false
TLS_KEY_FILE=
TLS_CERT_FILE=
TLS_CA_FILE=

